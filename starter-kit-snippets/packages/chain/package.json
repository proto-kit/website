{
  "name": "chain",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "watch": {
    "build-and-start": {
      "patterns": [
        "src"
      ],
      "extensions": [
        "*"
      ],
      "quiet": true
    }
  },
  "scripts": {
    "lint": "eslint .",
    "test": "node --experimental-vm-modules --experimental-wasm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "npm run test --watchAll",
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "start": "pnpm run sequencer:start",
    "sequencer:start": "node --loader ts-node/esm --experimental-vm-modules --experimental-wasm-modules --es-module-specifier-resolution=node ./dist/start.js start \"./core/environments/$PROTOKIT_ENV_FOLDER/chain.config.js\" $1",
    "indexer:start": "node --loader ts-node/esm --experimental-vm-modules --experimental-wasm-modules --es-module-specifier-resolution=node ./dist/start.js start \"./core/environments/$PROTOKIT_ENV_FOLDER/indexer.config.js\" $1",
    "processor:start": "node --loader ts-node/esm --experimental-vm-modules --experimental-wasm-modules --es-module-specifier-resolution=node ./dist/start.js start \"./core/environments/$PROTOKIT_ENV_FOLDER/processor.config.js\" $1",
    "dev": "pnpm run sequencer:dev",
    "sequencer:dev": "node --loader ts-node/esm --experimental-vm-modules --experimental-wasm-modules --es-module-specifier-resolution=node ./src/start.ts start \"./core/environments/$PROTOKIT_ENV_FOLDER/chain.config.ts\" $1",
    "indexer:dev:run": "node --loader ts-node/esm --experimental-vm-modules --experimental-wasm-modules --es-module-specifier-resolution=node ./src/start.ts start \"./core/environments/$PROTOKIT_ENV_FOLDER/indexer.config.ts\" $1",
    "processor:dev:run": "node --loader ts-node/esm --experimental-vm-modules --experimental-wasm-modules --es-module-specifier-resolution=node ./src/start.ts start \"./core/environments/$PROTOKIT_ENV_FOLDER/processor.config.ts\" $1",
    "sequencer:dev:2": "nodemon --watch src -e ts --exec \"pnpm sequencer:dev:run\"",
    "indexer:dev": "nodemon --watch src -e ts --exec \"pnpm indexer:dev:run\"",
    "processor:dev": "nodemon --watch src -e ts --exec \"pnpm processor:dev:run\"",
    "worker:dev": "node --loader ts-node/esm --experimental-vm-modules --experimental-wasm-modules --es-module-specifier-resolution=node ./src/start.ts start \"./core/environments/$PROTOKIT_ENV_FOLDER/worker.config.ts\" $1",
    "worker:dev:2": "nodemon --watch src -e ts --exec \"pnpm worker:dev:run\"",
    "prisma:generate": "pnpm run sequencer:prisma:generate && pnpm run indexer:prisma:generate && pnpm run processor:prisma:generate",
    "prisma:migrate": "pnpm run sequencer:prisma:migrate && pnpm run indexer:prisma:migrate && pnpm run processor:prisma:migrate",
    "sequencer:prisma:migrate": "prisma migrate deploy --schema ./node_modules/@proto-kit/persistance/prisma/schema.prisma",
    "sequencer:prisma:generate": "prisma generate --schema ./node_modules/@proto-kit/persistance/prisma/schema.prisma",
    "indexer:prisma:migrate": "prisma migrate deploy --schema ./node_modules/@proto-kit/indexer/prisma/schema.prisma",
    "indexer:prisma:generate": "prisma generate --schema ./node_modules/@proto-kit/indexer/prisma/schema.prisma",
    "processor:prisma:migrate:dev": "prisma migrate dev --schema ./src/core/processor/prisma/schema.prisma",
    "processor:prisma:migrate": "prisma migrate deploy --schema ./src/core/processor/prisma/schema.prisma",
    "processor:prisma:generate": "prisma generate --schema ./src/core/processor/prisma/schema.prisma",
    "mina-explorer:start": "node ./node_modules/mina-lightweight-explorer/server.js"
  },
  "peerDependencies": {
    "@proto-kit/api": "../../../../framework/packages/api",
    "@proto-kit/common": "../../../../framework/packages/common",
    "@proto-kit/deployment": "../../../../framework/packages/deployment",
    "@proto-kit/indexer": "../../../../framework/packages/indexer",
    "@proto-kit/library": "../../../../framework/packages/library",
    "@proto-kit/module": "../../../../framework/packages/module",
    "@proto-kit/persistance": "../../../../framework/packages/persistance",
    "@proto-kit/processor": "../../../../framework/packages/processor",
    "@proto-kit/protocol": "../../../../framework/packages/protocol",
    "@proto-kit/sdk": "../../../../framework/packages/sdk",
    "@proto-kit/sequencer": "../../../../framework/packages/sequencer",
    "@proto-kit/stack": "../../../../framework/packages/stack",
    "o1js": "../../../../framework/node_modules/o1js",
    "tsyringe": "../../../../framework/node_modules/tsyringe"
  },
  "optionalDependencies": {
    "@o1js/native": "2.14.0-dev.e1080"
  },
  "devDependencies": {
    "@jest/globals": "^29.6.1",
    "@prisma/client": "^5.18.0",
    "@types/jest": "^29.5.7",
    "@types/node": "^20.8.10",
    "@types/react-dom": "^18.2.7",
    "@types/yargs": "^17.0.32",
    "assert": "^2.0.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "eslint-config-custom": "workspace:*",
    "events": "^3.3.0",
    "graphql": "^16.8.1",
    "jest": "^29.6.1",
    "jest-expect-message": "^1.1.3",
    "loglevel": "^1.8.1",
    "nodemon": "^3.1.4",
    "npm-watch": "^0.11.0",
    "path-browserify": "^1.0.1",
    "prisma": "^5.18.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "ts-jest": "^29.1.1",
    "tsconfig": "workspace:*",
    "typegraphql-prisma": "^0.28",
    "typescript": "5.4.5",
    "url": "^0.11.1",
    "util": "^0.12.5",
    "yargs": "^17.7.2"
  },
  "dependencies": {
    "graphql-fields": "^2.0.3",
    "graphql-scalars": "^1.22.4",
    "mina-lightweight-explorer": "github:o1-labs/mina-lightweight-explorer",
    "reflect-metadata": "^0.1.13",
    "type-graphql": "2.0.0-rc.2",
    "mina-fungible-token": "^1.1.0"
  },
  "nodemonConfig": {
    "delay": 1000
  }
}
