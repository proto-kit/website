{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "ui": "tui",
  "envMode": "loose",
  "tasks": {
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "sequencer:dev": {
      "cache": false
    },
    "indexer:dev": {
      "cache": false
    },
    "processor:dev": {
      "cache": false
    },
    "test": {},
    "start": {
      "cache": false
    },
    "sequencer:start": {
      "cache": false
    },
    "indexer:start": {
      "cache": false
    },
    "processor:start": {
      "cache": false
    },
    "prisma:generate": {
      "cache": false
    },
    "prisma:migrate": {
      "cache": false
    },
    "sequencer:prisma:generate": {
      "cache": false
    },
    "sequencer:prisma:migrate": {
      "cache": false
    },
    "indexer:prisma:generate": {
      "cache": false
    },
    "indexer:prisma:migrate": {
      "cache": false
    },
    "processor:prisma:migrate:dev": {
      "cache": false,
      "interactive": true
    },
    "processor:prisma:generate": {
      "cache": false
    },
    "processor:prisma:migrate": {
      "cache": false
    },
    "start:headless": {},
    "generate-keys": {
      "cache": false
    },
    "lightnet:faucet": {
      "cache": false
    },
    "lightnet:wait-for-network": {
      "cache": false
    },
    "settlement:deploy": {
      "cache": false
    },
    "settlement:token:deploy": {
      "cache": false
    },
    "mina-explorer:start": {
      "cache": false
    },
    "worker:dev": {
      "cache": false
    },
    "bridge:deposit": {
      "cache": false
    },
    "bridge:withdraw": {
      "cache": false
    },
    "bridge:redeem": {
      "cache": false
    }
  }
}
